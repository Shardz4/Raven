# ── Raven Configuration ──

# Server
PORT=8080

# GitHub (optional for public repos, required for private)
# GITHUB_TOKEN=ghp_your_token_here

# ── LLM API Keys (set at least one) ──
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...
# XAI_API_KEY=xai-...

# ── RavenMind Consensus ──
# Judge model evaluates all passing patches (should be your strongest model)
JUDGE_PROVIDER=openai
JUDGE_MODEL=gpt-4o

# Number of LLMs to query in parallel
RAVEN_REDUNDANCY=3

# ── Docker Sandbox ──
DOCKER_TIMEOUT=60
SANDBOX_IMAGE=raven-sandbox:latest

# ── Database ──
DB_PATH=raven.db

# ── Bot Tokens (optional) ──
# TELEGRAM_BOT_TOKEN=...
# DISCORD_BOT_TOKEN=...
