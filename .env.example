# ── Raven Configuration ──

# Server
PORT=8080

# GitHub (optional for public repos, REQUIRED for auto-PR)
# GITHUB_TOKEN=ghp_your_token_here

# ── LLM API Keys (set at least one) ──
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...
# XAI_API_KEY=xai-...

# ── RavenMind Consensus ──

# Judge: evaluates all passing patches (pick your strongest model)
# Options: openai, anthropic, deepseek, grok, custom, none
JUDGE_PROVIDER=openai
JUDGE_MODEL=gpt-4o

# Custom Judge: plug in your own fine-tuned model
# Set JUDGE_PROVIDER=custom and configure these:
# CUSTOM_JUDGE_URL=http://localhost:5000/judge
# CUSTOM_JUDGE_KEY=your-api-key
# CUSTOM_JUDGE_MODEL=my-judge-v1

# Number of LLMs to query in parallel
RAVEN_REDUNDANCY=3

# ── Self-Healing ──
# When all patches fail, retry with error feedback (0 = disabled)
MAX_HEAL_RETRIES=2

# ── Auto PR ──
# Automatically fork + branch + open PR with winning patch
# Requires GITHUB_TOKEN. Set to any value to enable.
# AUTO_PR=true

# ── Docker Sandbox ──
DOCKER_TIMEOUT=60
SANDBOX_IMAGE=raven-sandbox:latest

# ── Database ──
DB_PATH=raven.db

# ── Bot Tokens (optional) ──
# TELEGRAM_BOT_TOKEN=...
# DISCORD_BOT_TOKEN=...
